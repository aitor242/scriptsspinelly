-- Función de teletransportación PERMANENTE
teleportButton.MouseButton1Click:Connect(function()
    if not basePosition or not baseCFrame then
        teleportButton.Text = "Marca una base primero"
        wait(1)
        teleportButton.Text = "Teletransportarse"
        return
    end
    
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then
        teleportButton.Text = "Error: Personaje no encontrado"
        wait(1)
        teleportButton.Text = "Teletransportarse"
        return
    end
    
    local humanoidRootPart = character.HumanoidRootPart
    local humanoid = character:FindFirstChild("Humanoid")
    
    -- Desactivar temporalmente el humanoid para evitar interferencias
    if humanoid then
        humanoid:ChangeState(Enum.HumanoidStateType.Physics)
    end
    
    -- Método agresivo de teletransportación
    humanoidRootPart.Anchored = true
    humanoidRootPart.CFrame = baseCFrame
    wait(0.1)
    humanoidRootPart.Anchored = false
    
    -- Desactivar la capacidad de movimiento del personaje
    if humanoid then
        humanoid.WalkSpeed = 0
        humanoid.JumpPower = 0
        humanoid.AutoRotate = false
    end
    
    -- Marcar como teletransportado permanentemente
    isTeleported = true
    
    -- Notificación visual
    local notification = Instance.new("TextLabel")
    notification.Parent = screenGui
    notification.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    notification.BorderSizePixel = 0
    notification.Position = UDim2.new(0.5, -100, 0, 50)
    notification.Size = UDim2.new(0, 200, 0, 30)
    notification.Font = Enum.Font.SourceSansBold
    notification.Text = "Teleportación PERMANENTE"
    notification.TextColor3 = Color3.fromRGB(255, 255, 255)
    notification.TextSize = 14
    notification.BackgroundTransparency = 0.3
    
    game:GetService("Debris"):AddItem(notification, 2)
end)

-- Botón para liberar el movimiento
releaseButton.MouseButton1Click:Connect(function()
    isTeleported = false
    
    local character = LocalPlayer.Character
    if character then
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.WalkSpeed = 16
            humanoid.JumpPower = 50
            humanoid.AutoRotate = true
            humanoid:ChangeState(Enum.HumanoidStateType.Running)
        end
    end
    
    releaseButton.Text = "Movimiento liberado"
    wait(1)
    releaseButton.Text = "Liberar Movimiento"
end)

-- Bucle para mantener permanentemente al personaje en la posición
RunService.Heartbeat:Connect(function()
    if isTeleported and basePosition then
        local character = LocalPlayer.Character
        if character and character:FindFirstChild("HumanoidRootPart") then
            local humanoidRootPart = character.HumanoidRootPart
            
            -- Forzar constantemente la posición
            humanoidRootPart.CFrame = baseCFrame
            
            -- Asegurar que no pueda moverse
            local humanoid = character:FindFirstChild("Humanoid")
            if humanoid then
                humanoid.WalkSpeed = 0
                humanoid.JumpPower = 0
                humanoid:ChangeState(Enum.HumanoidStateType.Physics)
            end
        end
    end
end)

