-- Script de teletransportación instantánea para Steal a Brainrot
-- Se teletransporta al presionar el botón, no al recoger el objeto

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Variables para almacenar coordenadas
local basePosition = nil
local baseCFrame = nil

-- Crear GUI simple
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = game:GetService("CoreGui")
screenGui.Name = "TeleportScript"
screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

local mainFrame = Instance.new("Frame")
mainFrame.Parent = screenGui
mainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
mainFrame.BorderSizePixel = 0
mainFrame.Position = UDim2.new(0, 10, 0, 10)
mainFrame.Size = UDim2.new(0, 200, 0, 100)
mainFrame.Active = true
mainFrame.Draggable = true

local markBaseButton = Instance.new("TextButton")
markBaseButton.Parent = mainFrame
markBaseButton.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
markBaseButton.BorderSizePixel = 0
markBaseButton.Position = UDim2.new(0, 10, 0, 10)
markBaseButton.Size = UDim2.new(0, 180, 0, 35)
markBaseButton.Font = Enum.Font.SourceSans
markBaseButton.Text = "Marcar Base"
markBaseButton.TextColor3 = Color3.fromRGB(255, 255, 255)
markBaseButton.TextSize = 18

local teleportButton = Instance.new("TextButton")
teleportButton.Parent = mainFrame
teleportButton.BackgroundColor3 = Color3.fromRGB(215, 0, 0)
teleportButton.BorderSizePixel = 0
teleportButton.Position = UDim2.new(0, 10, 0, 55)
teleportButton.Size = UDim2.new(0, 180, 0, 35)
teleportButton.Font = Enum.Font.SourceSans
teleportButton.Text = "Teletransportarse"
teleportButton.TextColor3 = Color3.fromRGB(255, 255, 255)
teleportButton.TextSize = 18

-- Función para guardar las coordenadas actuales
markBaseButton.MouseButton1Click:Connect(function()
    local character = LocalPlayer.Character
    if character and character:FindFirstChild("HumanoidRootPart") then
        -- Guardar tanto posición como rotación
        basePosition = character.HumanoidRootPart.Position
        baseCFrame = character.HumanoidRootPart.CFrame
        
        markBaseButton.Text = "Base Guardada ✓"
        wait(1)
        markBaseButton.Text = "Marcar Base"
        
        -- Notificación visual
        local notification = Instance.new("TextLabel")
        notification.Parent = screenGui
        notification.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        notification.BorderSizePixel = 0
        notification.Position = UDim2.new(0.5, -100, 0, 50)
        notification.Size = UDim2.new(0, 200, 0, 30)
        notification.Font = Enum.Font.SourceSansBold
        notification.Text = "Posición guardada: " .. math.floor(basePosition.X) .. ", " .. math.floor(basePosition.Y) .. ", " .. math.floor(basePosition.Z)
        notification.TextColor3 = Color3.fromRGB(255, 255, 255)
        notification.TextSize = 14
        notification.BackgroundTransparency = 0.3
        
        game:GetService("Debris"):AddItem(notification, 3)
    end
end)

-- Función de teletransportación instantánea
teleportButton.MouseButton1Click:Connect(function()
    if not basePosition or not baseCFrame then
        teleportButton.Text = "Marca una base primero"
        wait(1)
        teleportButton.Text = "Teletransportarse"
        return
    end
    
    local character = LocalPlayer.Character
    if character and character:FindFirstChild("HumanoidRootPart") then
        -- Teletransportación instantánea usando CFrame para preservar rotación
        character.HumanoidRootPart.CFrame = baseCFrame
        
        -- Notificación visual
        local notification = Instance.new("TextLabel")
        notification.Parent = screenGui
        notification.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        notification.BorderSizePixel = 0
        notification.Position = UDim2.new(0.5, -100, 0, 50)
        notification.Size = UDim2.new(0, 200, 0, 30)
        notification.Font = Enum.Font.SourceSansBold
        notification.Text = "Teletransportado a base"
        notification.TextColor3 = Color3.fromRGB(255, 255, 255)
        notification.TextSize = 14
        notification.BackgroundTransparency = 0.3
        
        game:GetService("Debris"):AddItem(notification, 2)
    end
end)

-- Bypass anti-cheat simple
for _, remote in pairs(game:GetDescendants()) do
    if remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction") then
        if remote.Name:lower():find("kick") or remote.Name:lower():find("ban") or 
           remote.Name:lower():find("report") or remote.Name:lower():find("cheat") or
           remote.Name:lower():find("detect") or remote.Name:lower():find("anticheat") then
            pcall(function()
                if remote:IsA("RemoteEvent") then
                    remote:Destroy()
                elseif remote:IsA("RemoteFunction") then
                    remote:Destroy()
                end
            end)
        end
    end
end

-- Notificación de que el script está cargado
local loadNotification = Instance.new("TextLabel")
loadNotification.Parent = screenGui
loadNotification.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
loadNotification.BorderSizePixel = 0
loadNotification.Position = UDim2.new(0.5, -100, 0, 50)
loadNotification.Size = UDim2.new(0, 200, 0, 30)
loadNotification.Font = Enum.Font.SourceSansBold
loadNotification.Text = "Script de teletransportación cargado"
loadNotification.TextColor3 = Color3.fromRGB(255, 255, 255)
loadNotification.TextSize = 14
loadNotification.BackgroundTransparency = 0.3

game:GetService("Debris"):AddItem(loadNotification, 3)
