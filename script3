game:GetService("ScriptContext").ErrorOutput:Connect(function(message)
    if message:find("kick") or message:find("ban") or message:find("cheat") or 
       message:find("detect") or message:find("anticheat") then
        return true -- Bloquear mensajes de detección
    end
end)

