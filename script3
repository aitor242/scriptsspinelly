-- Función para teletransportarse instantáneamente a la base
local function teleportToBase()
    if not basePosition then
        return false
    end
    
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then
        return false
    end
    
    -- Teletransportación instantánea sin lag
    local humanoidRootPart = character.HumanoidRootPart
    
    -- Desactivar temporalmente el sistema de física para evitar detección
    humanoidRootPart.Anchored = true
    
    -- Teletransportación directa
    humanoidRootPart.CFrame = CFrame.new(basePosition)
    
    -- Reactivar la física
    humanoidRootPart.Anchored = false
    
    return true
end

-- Función para comprobar si tenemos el brainrot
local function checkForBrainrot()
    local character = LocalPlayer.Character
    if character then
        -- Comprobar en el personaje
        for _, item in pairs(character:GetChildren()) do
            if item.Name == brainrotName and item:IsA("Tool") then
                return true
            end
        end
        
        -- Comprobar en el backpack
        local backpack = LocalPlayer:FindFirstChild("Backpack")
        if backpack then
            for _, item in pairs(backpack:GetChildren()) do
                if item.Name == brainrotName and item:IsA("Tool") then
                    return true
                end
            end
        end
    end
    return false
end

-- Eventos de botones
markBaseButton.MouseButton1Click:Connect(function()
    local character = LocalPlayer.Character
    if character and character:FindFirstChild("HumanoidRootPart") then
        basePosition = character.HumanoidRootPart.Position
        markBaseButton.Text = "Base Guardada ✓"
        wait(1)
        markBaseButton.Text = "Marcar Base"
    end
end)

autoStealButton.MouseButton1Click:Connect(function()
    if not basePosition then
        autoStealButton.Text = "Marca Base Primero"
        wait(1)
        autoStealButton.Text = "Auto Steal: OFF"
        return
    end
    
    autoStealEnabled = not autoStealEnabled
    if autoStealEnabled then
        autoStealButton.BackgroundColor3 = Color3.fromRGB(215, 0, 0)
        autoStealButton.Text = "Auto Steal: ON"
    else
        autoStealButton.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
        autoStealButton.Text = "Auto Steal: OFF"
    end
end)

-- Bucle principal para detectar cuando recogemos el brainrot
RunService.Heartbeat:Connect(function()
    if not autoStealEnabled then return end
    
    -- Limitar las comprobaciones para evitar lag
    local currentTime = tick()
    if currentTime - lastBrainrotCheck < 0.1 then return end
    lastBrainrotCheck = currentTime
    
    -- Comprobar si tenemos el brainrot
    local currentlyHasBrainrot = checkForBrainrot()
    
    -- Si acabamos de recoger el brainrot, teletransportarnos a la base
    if currentlyHasBrainrot and not hasBrainrot then
        hasBrainrot = true
        teleportToBase()
    elseif not currentlyHasBrainrot then
        hasBrainrot = false
    end
end)

-- Bypass anti-cheat mejorado
local originalFireServer = {}
local originalInvokeServer = {}

-- Interceptamos todos los RemoteEvents y RemoteFunctions para evitar detección
for _, remote in pairs(game:GetDescendants()) do
    if remote:IsA("RemoteEvent") then
        if remote.Name:lower():find("kick") or remote.Name:lower():find("ban") or 
           remote.Name:lower():find("report") or remote.Name:lower():find("cheat") or
           remote.Name:lower():find("detect") or remote.Name:lower():find("anticheat") then
            originalFireServer[remote] = remote.FireServer
            remote.FireServer = function(...) end
        end
    elseif remote:IsA("RemoteFunction") then
        if remote.Name:lower():find("kick") or remote.Name:lower():find("ban") or 
           remote.Name:lower():find("report") or remote.Name:lower():find("cheat") or
           remote.Name:lower():find("detect") or remote.Name:lower():find("anticheat") then
            originalInvokeServer[remote] = remote.InvokeServer
            remote.InvokeServer = function(...) return nil end
        end
    end
end

