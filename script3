local autoStealButton = Instance.new("TextButton")
autoStealButton.Parent = mainFrame
autoStealButton.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
autoStealButton.BorderSizePixel = 0
autoStealButton.Position = UDim2.new(0, 10, 0, 55)
autoStealButton.Size = UDim2.new(0, 180, 0, 35)
autoStealButton.Font = Enum.Font.SourceSans
autoStealButton.Text = "Auto Steal: OFF"
autoStealButton.TextColor3 = Color3.fromRGB(255, 255, 255)
