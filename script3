-- Steal a Brainrot Script para Xeno - Versión Mejorada
-- Teletransportación instantánea al recoger el brainrot

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

-- Variables
local basePosition = nil
local autoStealEnabled = false
local brainrotName = "Brainrot" -- Cambia esto si el objeto tiene otro nombre
local hasBrainrot = false
local lastBrainrotCheck = 0

-- Crear GUI
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = game:GetService("CoreGui")
